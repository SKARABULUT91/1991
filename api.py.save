from flask import Flask, request, jsonify
from flask_cors import CORS
import os
import subprocess
import json

app = Flask(__name__)
# Dashboard'un (Frontend) API'ye sorunsuz erişmesi için CORS'u aktif ettik
CORS(app)

# Yapılandırma
REPORT_FILE = "gorev_raporu.json"
LOCK_FILE = "bot.lock"

@app.route('/')
def home():
    return jsonify({
        "ajans": "Kodcum Ajans",
        "durum": "API Sunucusu Aktif",
        "mesaj": "Hayalet operasyona hazır! 🚀"
    }), 200

@app.route('/api/bot-report', methods=['GET'])
def get_report():
    """Botun topladığı verileri Dashboard'a gönderir."""
    if not os.path.exists(REPORT_FILE):
        return jsonify([]), 200
    
    try:
        with open(REPORT_FILE, 'r', encoding='utf-8') as f:
            data = json.load(f)
            return jsonify(data), 200
    except Exception as e:
        return jsonify({"error": str(e)}), 500

6@app.route('/api/run-bot', methods=['POST'])
def run_bot():
    """Botu kilit mekanizmasıyla güvenli şekilde başlatır."""
    # 1. Kontrol: Bot zaten çalışıyor mu?
    if os.path.exists(LOCK_FILE):
        return jsonify({
            "status": "error",
            "message": "Sistem zaten aktif! Birden fazla bot çalıştırılamaz."
        }), 400

    try:
        # 2. Kilit dosyasını oluştur
        with open(LOCK_FILE, 'w') as f:
            f.write("running")

        # 3. Bot engine dosyasını başlat 
        # (Dosya adın farklıysa 'bot_engine.py' kısmını değiştir)
        subprocess.Popen(["python3", "bot_engine.py"])
        
        return jsonify({
            "status": "success",
            "message": "Hayalet operasyonu başlatıldı. Veriler akmaya başlayacak."
        }), 200

    except Exception as e:
        # Hata durumunda kilidi kaldır ki sistem kilitli kalmasın
        if os.path.exists(LOCK_FILE):
            os.remove(LOCK_FILE)
        return jsonify({"status": "error", "message": str(e)}), 500

@app.route('/api/status', methods=['GET'])
def get_status():
    """Botun fiziksel olarak çalışıp çalışmadığını lock dosyasından anlar."""
    is_active = os.path.exists(LOCK_FILE)
    return jsonify({"active": is_active}), 200

if __name__ == '__main__':
    # host='0.0.0.0' dış erişime açar, debug=True kod değişiminde oto-yeniler
    app.run(host='0.0.0.0', port=5000, debug=True)
